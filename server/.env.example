PORT=4000
NODE_ENV=development

# SQLite file path (relative to project root)
DATABASE_URL="file:./dev.db"

# Change these in any real deployment
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Frontend origin allowed to call the API / connect over Socket.IO
CORS_ORIGIN="http://localhost:3000"

# Market data provider (XT.com public API, no key required)
MARKET_DATA_BASE_URL="https://sapi.xt.com"

# How often the candle scheduler polls (seconds). Use a divisor of 60 (1,2,3,5,6,10,15,20,30) for
# second-level precision; any other value falls back to per-minute polling.
POLL_INTERVAL_SECONDS=30
